[
  {
    "id": 1,
    "name": "underage_check",
    "category": "Statutory Compliance",
    "description": "Ensures no employees are under the age of 18 as per labour laws.",
    "content": {
      "contentType": "application/vnd.gorules.decision",
      "nodes": [
        {
          "id": "node-1",
          "name": "Underage Check Table",
          "type": "decisionTableNode",
          "position": { "x": 100, "y": 100 },
          "content": {
            "hitPolicy": "first",
            "inputs": [{"id": "in-1", "name": "Age", "field": "age"}],
            "outputs": [{"id": "out-1", "name": "Violation", "field": "isViolator"}],
            "rules": [
              {"in-1": "< 18", "out-1": "true"},
              {"in-1": ">= 18", "out-1": "false"}
            ]
          }
        }
      ],
      "edges": []
    }
  },
